# ── Optional: AI Chat Agent (agent.py) ──
# Only needed if you want the interactive Claude-powered chat agent.
# The planner, emailer, and scheduler work without this.
ANTHROPIC_API_KEY=sk-ant-...

# ── Required: Email Reminders (scheduler.py / emailer.py) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
RECIPIENT_EMAIL=your-email@gmail.com

# ── Optional: Bond Plan Configuration (defaults shown) ──
TOTAL_INVESTMENT=100000
NUM_BATCHES=10
TBILL_RATE=0.045
# START_DATE=2026-05-01  # Uncomment to set a specific start date
